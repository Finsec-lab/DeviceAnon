<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="14dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:text="DeviceAnon"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="2dp"
            android:text="FinSec"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Pages -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <include layout="@layout/tab_home" />
        <include layout="@layout/tab_devices" />
        <include layout="@layout/tab_about" />
    </FrameLayout>

    <!-- Bottom nav -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/hairline" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:orientation="horizontal"
        android:background="@color/bg">

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground">
            <ImageView android:id="@+id/ic_home" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_tab_home" />
            <TextView android:id="@+id/tl_home" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Device" android:textSize="11sp" android:layout_marginTop="3dp" android:textColor="@color/text_muted" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_devices"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground">
            <ImageView android:id="@+id/ic_devices" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_tab_devices" />
            <TextView android:id="@+id/tl_devices" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Catalog" android:textSize="11sp" android:layout_marginTop="3dp" android:textColor="@color/text_muted" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_about"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground">
            <ImageView android:id="@+id/ic_about" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_tab_about" />
            <TextView android:id="@+id/tl_about" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="About" android:textSize="11sp" android:layout_marginTop="3dp" android:textColor="@color/text_muted" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
